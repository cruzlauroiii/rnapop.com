@page "/guide"
@page "/guide/{StepParam}"
@page "/guide/make/{ProtocolStepParam}"
@implements IAsyncDisposable
@inject LabWsClient LabClient
@inject EnvWsClient EnvClient
@inject QcWsClient QcClient
@inject NavigationManager Nav

<PageTitle>Step-by-Step Guide</PageTitle>

<div class="wizard-page">
    @if (_simulation)
    {
        <div class="wiz-sim-badge">SIMULATION MODE — no real lab equipment connected, all steps simulated</div>
    }
    <div class="wizard-progress">
        <div class="wiz-progress-bar">
            <div class="wiz-progress-fill" style="width: @(ProgressPercent)%"></div>
        </div>
        <span class="wiz-progress-text">Step @(_step + 1) of @TotalSteps</span>
    </div>

    <div class="wizard-content">
        @switch (_phase)
        {
            // ========== PHASE 1: LEARN & CHOOSE ==========
            case Phase.Welcome:
                <h2>Welcome — Let's Make Medicine Together</h2>
                <div class="wiz-learn">
                    <h3>What is this?</h3>
                    <p>This app helps you create <strong>mRNA medicine</strong> — the same technology used in COVID vaccines (Pfizer, Moderna). Instead of buying medicine from a pharmacy, you'll make it yourself using simple lab equipment that costs about $250 total.</p>

                    <h3>What is mRNA?</h3>
                    <p><strong>mRNA</strong> (messenger RNA) is a tiny instruction sheet that tells your cells what to build. In a COVID vaccine, the mRNA tells your cells to build a harmless piece of the virus so your immune system can learn to fight it. Here, we use mRNA to tell your cells to build whatever protein you need — antibodies to fight a cold, growth factors to heal a wound, or rejuvenation signals to reverse aging.</p>

                    <h3>Is it safe?</h3>
                    <p>mRNA breaks down naturally in your body within 24-48 hours — it doesn't change your DNA or stay permanently. That's actually one of its biggest advantages: the effect is temporary and controlled. However, most of these therapies are still in research. The COVID vaccines are the only FDA-approved mRNA products. Everything else here is experimental.</p>

                    <h3>What will I need?</h3>
                    <p>You'll need: (1) this app (free, runs in your browser), (2) lab equipment controlled by ESP32 chips (~$250 in parts), and (3) chemical reagents (~$1,600 — these are the "ingredients" that can't be made at home). Total: about $2,000 for everything.</p>

                    <h3>How long does it take?</h3>
                    <p>The entire process takes about 6-8 hours spread over one day. Most of that is waiting — the actual hands-on work is about 1 hour total.</p>
                </div>
                break;

            case Phase.ChooseTherapy:
                <h2>What health issue do you want to address?</h2>
                <p class="wiz-explain">Pick one. Don't worry — you can always come back and try a different one later.</p>
                <div class="wiz-choices">
                    @foreach (var t in TherapyCatalog.All)
                    {
                        var therapy = t;
                        <button class="wiz-choice @(_selectedTherapy?.Id == therapy.Id ? "selected" : "")" @onclick="() => _selectedTherapy = therapy">
                            <strong>@therapy.Name</strong>
                            <span>@GetSimpleDescription(therapy.Id)</span>
                            <small class="therapy-status status-@StatusClass(therapy.Status)">@GetStatusExplain(therapy.Status)</small>
                        </button>
                    }
                </div>
                break;

            case Phase.LearnTherapy:
                <h2>How @(_selectedTherapy!.Name) Works</h2>
                <div class="wiz-learn">
                    <h3>The problem</h3>
                    <p>@GetProblemExplain(_selectedTherapy.Id)</p>

                    <h3>The solution</h3>
                    <p>@GetSolutionExplain(_selectedTherapy.Id)</p>

                    <h3>What the mRNA does inside your body</h3>
                    <p>@_selectedTherapy.Mechanism</p>

                    <h3>What we'll make</h3>
                    @foreach (var c in _selectedTherapy.Constructs)
                    {
                        <div class="wiz-construct">
                            <strong>@c.Name</strong>
                            <p>@c.Function</p>
                            <p class="wiz-field-help">This is a piece of mRNA that is @c.LengthNt "letters" long (nucleotides — the building blocks of RNA, like letters in a word). We get the recipe from @c.Source.</p>
                        </div>
                    }

                    <h3>How you'll take it</h3>
                    <p>@_selectedTherapy.LnpFormulation</p>
                    <p class="wiz-field-help"><strong>LNP</strong> = Lipid Nanoparticle. Think of it as a tiny bubble made of fat, about 1000x smaller than a human hair. The mRNA goes inside this bubble so it can survive in your body and get into your cells. Without the bubble, the mRNA would be destroyed by enzymes in your blood within seconds.</p>

                    <h3>Current status</h3>
                    <p>@_selectedTherapy.Status</p>
                    <p class="wiz-field-help">
                        <strong>Research</strong> = only tested in lab dishes and sometimes in animals. No human data yet.<br/>
                        <strong>Preclinical</strong> = tested in animals with good results. Getting ready for human trials.<br/>
                        <strong>Clinical</strong> = currently being tested in real people in a formal medical trial.<br/>
                        <strong>Approved</strong> = officially approved by the FDA (like COVID vaccines). Safe to use.
                    </p>
                </div>
                break;

            case Phase.EnterInfo:
                <h2>Tell us about yourself</h2>
                <p class="wiz-explain">We need some basic information to check if this therapy is right and calculate the correct dose. This works for both <strong>humans and pets</strong> — just select who it's for. <strong>All data stays in your browser.</strong></p>
                <div class="wiz-form">
                    <label class="wiz-field">
                        <span class="wiz-field-name">Who is this for?</span>
                        <select @bind="_input.Species">
                            <option value="@Species.Human">Human</option>
                            <option value="@Species.Dog">Dog</option>
                            <option value="@Species.Cat">Cat</option>
                            <option value="@Species.Horse">Horse</option>
                            <option value="@Species.Other">Other animal</option>
                        </select>
                        <span class="wiz-field-help">mRNA therapy works in all mammals. The same mRNA constructs are used — only the dose changes based on body weight. Merck already sells mRNA vaccines for dogs (canine flu) and cats (feline leukemia) under the Nobivac NXT brand.</span>
                    </label>
                    @if (_input.Species != Species.Human)
                    {
                        <label class="wiz-field">
                            <span class="wiz-field-name">Breed (optional)</span>
                            <input type="text" @bind="_input.PetBreed" placeholder="e.g. Golden Retriever, Siamese" />
                            <span class="wiz-field-help">Some breeds have different sensitivities. Small breeds need lower doses.</span>
                        </label>
                    }
                    <label class="wiz-field">
                        <span class="wiz-field-name">@(_input.Species == Species.Human ? "How old are you?" : $"How old is the {_input.Species.ToString().ToLower()}?")</span>
                        <input type="number" @bind="_input.Age" />
                        <span class="wiz-field-help">@(_input.Species == Species.Human ? "Your age affects reference ranges and dose." : "In animal years. Dogs: 1-15, cats: 1-20, horses: 1-30.")</span>
                    </label>
                    <label class="wiz-field">
                        <span class="wiz-field-name">Biological sex</span>
                        <select @bind="_input.Sex"><option value="@Sex.Male">Male</option><option value="@Sex.Female">Female</option></select>
                    </label>
                    <label class="wiz-field">
                        <span class="wiz-field-name">Weight</span>
                        <input type="number" step="0.5" @bind="_input.WeightKg" /> kg
                        <span class="wiz-field-help">@(_input.Species switch { Species.Dog => "Small dog: 3-10kg, medium: 10-25kg, large: 25-45kg, giant: 45-80kg", Species.Cat => "Most cats: 3-6kg", Species.Horse => "Most horses: 400-600kg", _ => "Average adult human: 60-80kg" })</span>
                    </label>
                </div>

                @if (_selectedTherapy?.Id is "common-cold" or "influenza" or "covid19")
                {
                    <h3>Your symptoms</h3>
                    <p class="wiz-explain">The most important thing here is <strong>when you first got sick</strong>. mRNA medicine works best when taken early — before the virus has had time to multiply to its peak.</p>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">When did you first feel sick?</span>
                            <input type="number" @bind="_input.SymptomOnsetHours" /> hours ago
                            <span class="wiz-field-help">Try to remember the very first moment you felt "off." @(_selectedTherapy.Id == "common-cold" ? "For a cold, treatment works best within 24 hours." : _selectedTherapy.Id == "influenza" ? "For flu, treatment works best within 48 hours." : "For COVID, treatment works within 5 days (120 hours).")</span>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">What's your temperature right now?</span>
                            <input type="number" step="0.1" @bind="_input.TemperatureCelsius" /> °C
                            <span class="wiz-field-help">Use a thermometer. <strong>Normal</strong> = 36.5-37.5°C. <strong>Fever</strong> = above 38.0°C. A fever means your immune system is already fighting hard — and might mean this isn't just a cold (could be flu or COVID).</span>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">How bad do you feel overall?</span>
                            <input type="number" min="1" max="10" @bind="_input.SeverityScore" />
                            <span class="wiz-field-help">1 = "I barely notice anything." 5 = "I feel pretty bad but can still get things done." 10 = "I'm in bed and can't function."</span>
                        </label>
                        <div class="wiz-checkboxes">
                            <span class="wiz-field-name">Check everything you're experiencing:</span>
                            <label><input type="checkbox" @bind="_input.HasCough" /> Cough</label>
                            <label><input type="checkbox" @bind="_input.HasSoreThroat" /> Sore throat</label>
                            <label><input type="checkbox" @bind="_input.HasCongestion" /> Stuffy or runny nose</label>
                            <label><input type="checkbox" @bind="_input.HasBodyAches" /> Body aches or muscle pain</label>
                            <label><input type="checkbox" @bind="_input.HasFatigue" /> Feeling very tired</label>
                            <label><input type="checkbox" @bind="_input.HasHeadache" /> Headache</label>
                        </div>
                    </div>
                }
                @if (_selectedTherapy?.Id == "covid19")
                {
                    <h3>COVID vaccination history</h3>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">How many COVID vaccine shots total?</span>
                            <input type="number" min="0" @bind="_input.VaccinationDoses" />
                            <span class="wiz-field-help">Count all of them — first two shots plus any boosters. If you've never been vaccinated, put 0.</span>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">How long ago was your last shot?</span>
                            <input type="number" @bind="_input.DaysSinceLastVaccine" /> days
                            <span class="wiz-field-help">If it was about 6 months ago, that's roughly 180 days. Vaccine protection fades after about 6 months.</span>
                        </label>
                    </div>
                }
                @if (_selectedTherapy?.Id == "wound-healing")
                {
                    <h3>About your wound</h3>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">What kind of wound?</span>
                            <select @bind="_input.WoundType"><option value="">Pick one...</option><option>Surgical</option><option>Diabetic ulcer</option><option>Burns</option><option>Chronic/pressure</option><option>Traumatic</option></select>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">How big is the wound?</span>
                            <input type="number" step="0.5" @bind="_input.WoundAreaCm2" /> cm²
                            <span class="wiz-field-help">Measure the wound's length and width in centimeters, then multiply. A wound that's 3cm long and 5cm wide = 15 cm².</span>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">How many days old is the wound?</span>
                            <input type="number" @bind="_input.WoundAgeDays" /> days
                            <span class="wiz-field-help">A "chronic" wound (over 30 days old that isn't healing) benefits most from this therapy.</span>
                        </label>
                        <label><input type="checkbox" @bind="_input.IsDiabetic" /> I have diabetes</label>
                    </div>
                }
                @if (_selectedTherapy?.Id == "hair-regrowth")
                {
                    <h3>Hair loss details</h3>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">How much hair have you lost?</span>
                            <input type="number" min="1" max="7" @bind="_input.HairLossScale" />
                            <span class="wiz-field-help">1 = barely noticeable thinning. 3 = clear receding/thinning. 5 = large bare areas. 7 = mostly bald on top. Lower numbers = better chance of regrowth because the hair roots (follicles) are still alive, just asleep.</span>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">How many years have you been losing hair?</span>
                            <input type="number" @bind="_input.HairLossYears" />
                        </label>
                    </div>
                }
                @if (_selectedTherapy?.Id == "muscle-loss")
                {
                    <h3>Muscle strength</h3>
                    <p class="wiz-explain">These measurements come from a doctor or physical therapist. If you don't have them, ask your doctor for a "sarcopenia screening."</p>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">Grip strength</span>
                            <input type="number" step="0.5" @bind="_input.GripStrengthKg" /> kg
                            <span class="wiz-field-help">Squeeze a grip dynamometer as hard as you can. <strong>Low</strong> = below 27 kg for men, below 16 kg for women. You can buy a grip meter on Amazon for ~$25, or a doctor can test this.</span>
                        </label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">Muscle mass index</span>
                            <input type="number" step="0.1" @bind="_input.MuscleMassIndex" /> kg/m²
                            <span class="wiz-field-help">This requires a body scan (DXA or bioimpedance). Your doctor divides your arm+leg muscle weight by your height squared. <strong>Low</strong> = below 7.0 for men, below 5.5 for women.</span>
                        </label>
                        <label><input type="checkbox" @bind="_input.HasFalls" /> I've fallen in the past 12 months</label>
                    </div>
                }
                @if (_selectedTherapy?.Id == "allergy")
                {
                    <h3>Your allergies</h3>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">How bad are your allergies?</span>
                            <input type="number" min="1" max="10" @bind="_input.AllergySeverity" />
                            <span class="wiz-field-help">1 = occasional sneezing. 5 = daily symptoms, need antihistamines. 10 = severely impacts my life, nothing helps enough.</span>
                        </label>
                        <div class="wiz-checkboxes">
                            <span class="wiz-field-name">What are you allergic to? (check all that apply)</span>
                            @foreach (var a in _allergenOptions)
                            {
                                var name = a;
                                <label><input type="checkbox" checked="@_allergens.Contains(name)" @onchange="e => ToggleAllergen(name, (bool)e.Value!)" /> @name</label>
                            }
                        </div>
                    </div>
                }
                @if (_selectedTherapy?.Id == "cancer-neoantigen")
                {
                    <h3>Cancer details</h3>
                    <p class="wiz-explain">This therapy is personalized to YOUR specific tumor. It requires a tissue sample (biopsy) from the tumor and a blood test (HLA typing). If you don't have these, your oncologist can order them.</p>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">What type of cancer?</span>
                            <select @bind="_input.TumorType"><option value="">Pick one...</option><option>Melanoma</option><option>Pancreatic</option><option>Colorectal</option><option>Lung (NSCLC)</option><option>Breast</option><option>Head & Neck</option><option>Other</option></select>
                        </label>
                        <label><input type="checkbox" @bind="_input.TumorBiopsyAvailable" /> I have a tumor biopsy available</label>
                        <label class="wiz-field">
                            <span class="wiz-field-name">HLA type</span>
                            <input type="text" @bind="_input.HlaType" placeholder="e.g. HLA-A*02:01" />
                            <span class="wiz-field-help"><strong>HLA</strong> = Human Leukocyte Antigen. It's like a "name tag" on your cells. The cancer vaccine needs to know your HLA type to design proteins that your immune system can recognize. A simple blood test reveals this.</span>
                        </label>
                    </div>
                }
                break;

            case Phase.ShowResult:
                <h2>Your Assessment Result</h2>
                @if (_result is not null)
                {
                    <div class="wiz-result @(_result.Verdict == TherapyVerdict.Recommended ? "good" : _result.Verdict == TherapyVerdict.Conditional ? "okay" : "bad")">
                        <div class="wiz-result-verdict">
                            @(_result.Verdict == TherapyVerdict.Recommended ? "Recommended — this therapy is a good fit for you"
                              : _result.Verdict == TherapyVerdict.Conditional ? "Possible — may help, but with some conditions"
                              : "Not recommended right now — see why below")
                        </div>
                        <div class="wiz-result-score">Confidence: @_result.ConfidenceScore.ToString("F0") out of 100</div>
                    </div>

                    <div class="wiz-learn">
                        <h3>What this means</h3>
                        <p>@_result.Summary</p>

                        <h3>What we'll make for you</h3>
                        @foreach (var c in _result.Constructs)
                        {
                            <div class="wiz-construct">
                                <strong>@c.Name</strong> — @c.Function
                            </div>
                        }

                        <h3>How you'll take it: @_result.DeliveryInfo.DisplayName @_result.DeliveryInfo.Icon</h3>
                        <p>@_result.DeliveryInfo.ShortDescription</p>
                        <p><strong>Amount:</strong> @_result.Dose.AmountUg micrograms (µg) — that's about @((_result.Dose.AmountUg / 1000.0).ToString("F2")) milligrams, an incredibly tiny amount. For reference, a grain of salt weighs about 60,000 µg.</p>
                        <p><strong>Schedule:</strong> @_result.Dose.Schedule</p>

                        @if (_result.Warnings.Length > 0)
                        {
                            <h3>Important things to know</h3>
                            <ul class="wiz-warnings">@foreach (var w in _result.Warnings) { <li>@w</li> }</ul>
                        }
                    </div>
                }
                break;

            // ========== PHASE 2: CONNECT LAB ==========
            case Phase.ConnectLab:
                <h2>Connect to Your Lab Equipment</h2>
                <div class="wiz-learn">
                    <h3>What's happening here?</h3>
                    <p>Your lab equipment is controlled by small, cheap computer chips called <strong>ESP32</strong> (they cost $4 each). These chips are wired to every piece of equipment — the heater, the pumps, the measuring devices, everything.</p>
                    <p>This app talks to those chips over your WiFi network using something called <strong>WebSocket</strong> (WSS). Think of it like a live phone call:</p>
                    <div class="wiz-instruction">
                        <p>
                            <strong>This app</strong> says: "Heat to 37 degrees"<br/>
                            ↕ WiFi<br/>
                            <strong>Lab equipment</strong> does it, then says back: "Temperature is now 36.8° and rising..."
                        </p>
                    </div>
                    <p>This "phone call" happens twice per second, so you see live readings on screen.</p>

                    <h3>Don't have hardware yet?</h3>
                    <p>That's fine! You can practice with a simulator. Open a command prompt on your computer and type:</p>
                    <div class="wiz-instruction"><p><code>dotnet run --project src/MockEsp32</code></p></div>
                    <p>It will show an address like <code>wss://0.0.0.0:9983</code>. Use <code>wss://localhost:9983</code> below.</p>

                    <h3>Enter the address and connect</h3>
                    <div class="wiz-form">
                        <label class="wiz-field">
                            <span class="wiz-field-name">Lab address</span>
                            <input type="text" @bind="_wssUrl" />
                            <span class="wiz-field-help">Paste the address your lab equipment showed when it started up, or use wss://localhost:9983 for the simulator.</span>
                        </label>
                    </div>
                </div>

                @if (LabClient.Connected)
                {
                    <div class="wiz-result good"><div class="wiz-result-verdict">Connected — all instruments online</div></div>
                }
                else if (_connectError is not null)
                {
                    <div class="wiz-result okay">
                        <div class="wiz-result-verdict">Could not connect to lab — but you can still continue!</div>
                    </div>
                    <p class="wiz-explain">
                        The app couldn't reach the lab equipment at <code>@_wssUrl</code>. This is normal if:
                    </p>
                    <ul class="wiz-warnings">
                        <li>You don't have hardware yet (most people start here)</li>
                        <li>You're viewing this from GitHub Pages (can't reach localhost)</li>
                        <li>The mock server isn't running on your computer</li>
                    </ul>
                    <p class="wiz-explain">
                        <strong>Click Next to continue in SIMULATION MODE.</strong> You'll go through every step of the protocol
                        exactly as you would with real equipment — see all the instructions, learn what each step does,
                        and understand the full process. The only difference is the equipment readings are simulated numbers
                        instead of real sensor data. When you get your hardware later, you can come back and do it for real.
                    </p>
                }
                else
                {
                    <p class="wiz-explain">Or click Next to <strong>skip connecting</strong> and run through the protocol in simulation mode — great for learning!</p>
                }
                break;

            // ========== PHASE 3: PROTOCOL STEPS ==========
            case Phase.ProtocolStep:
                @if (_protocol is not null && _protocolStepIdx < _protocol.Steps.Length)
                {
                    var ps = _protocol.Steps[_protocolStepIdx];
                    <h2>Making your mRNA — Step @(ps.Order) of @(_protocol.Steps.Length)</h2>
                    <div class="wiz-progress-bar" style="margin-bottom:1rem;">
                        <div class="wiz-progress-fill" style="width: @(100.0 * (_protocolStepIdx + 1) / _protocol.Steps.Length)%"></div>
                    </div>

                    <h3>@ps.Name</h3>

                    <div class="wiz-learn">
                        <h3>Why this step?</h3>
                        <p>@GetWhyExplain(ps)</p>

                        <h3>What to do</h3>
                        <div class="wiz-instruction">
                            <p>@GetPlainInstruction(ps)</p>
                        </div>

                        @if (ps.Temperature > 0 || ps.DurationMinutes > 0 || ps.TargetRpm > 0 || ps.Voltage > 0)
                        {
                            <h3>Settings</h3>
                            @if (ps.Temperature > 0) { <p><strong>Temperature:</strong> @ps.Temperature°C @(ps.Temperature == 37 ? "(body temperature — enzymes work best here)" : "")</p> }
                            @if (ps.TargetRpm > 0) { <p><strong>Centrifuge speed:</strong> @ps.TargetRpm RPM (revolutions per minute — how fast the tube spins)</p> }
                            @if (ps.Voltage > 0) { <p><strong>Voltage:</strong> @ps.Voltage V (volts — the electrical force that pushes RNA through the gel)</p> }
                        }

                        @if (!string.IsNullOrEmpty(ps.Notes))
                        {
                            <h3>Detailed notes (for advanced users)</h3>
                            <p class="wiz-field-help">@ps.Notes</p>
                        }
                    </div>

                    @if (_timerRunning)
                    {
                        <div class="wiz-timer">
                            <div class="wiz-timer-display">@(_timerRemaining / 60):@((_timerRemaining % 60).ToString("D2"))</div>
                            <div class="wiz-timer-label">@(_timerRemaining > 0 ? "Waiting... don't touch anything." : "Time's up! Click Next to continue.")</div>
                            <div class="wiz-progress-bar">
                                <div class="wiz-progress-fill wiz-timer-bar" style="width: @(100.0 * (1.0 - (double)_timerRemaining / _timerTotal))%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <h2>You did it!</h2>
                    <div class="wiz-result good">
                        <div class="wiz-result-verdict">Your @(_selectedTherapy?.Name) mRNA is ready</div>
                    </div>
                    <div class="wiz-learn">
                        <h3>What you just accomplished</h3>
                        <p>You completed all @(_protocol?.Steps.Length ?? 0) steps. You now have mRNA wrapped in lipid nanoparticles (LNPs) — the same format as a COVID vaccine. Store it at -80°C (use the lab freezer) until you're ready to use it.</p>
                        <h3>Next: taking the medicine</h3>
                        <p>@_result?.DeliveryInfo.Preparation</p>
                        <p>@_result?.DeliveryInfo.Administration</p>
                        <p>@_result?.DeliveryInfo.PostCare</p>
                    </div>
                }
                break;
        }
    </div>

    <div class="wizard-buttons">
        @if (_step > 0 && !_timerRunning)
        {
            <button class="btn-secondary" @onclick="Back">Back</button>
        }
        <button class="btn-primary" @onclick="Next" disabled="@(!CanGoNext)">
            @NextButtonText
        </button>
    </div>
</div>

@code {
    enum Phase { Welcome, ChooseTherapy, LearnTherapy, EnterInfo, ShowResult, ConnectLab, ProtocolStep }

    [Parameter] public string? StepParam { get; set; }
    [Parameter] public string? ProtocolStepParam { get; set; }

    private Phase _phase = Phase.Welcome;
    private int _step = 0;
    private TherapyOption? _selectedTherapy;
    private TherapyInput _input = new();
    private TherapyResult? _result;
    private IvtProtocol? _protocol;
    private int _protocolStepIdx = 0;
    private string _wssUrl = "wss://localhost:9983";
