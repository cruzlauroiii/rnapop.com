    static string GetWhyExplain(IvtStep step)
    {
        if (step.Name.Contains("Template Prep")) return "Before we can make mRNA, we need a DNA template — like a master copy of a document that the copying machine (T7 enzyme) will read. This step prepares that master copy by cutting the circular plasmid DNA into a straight line so the enzyme knows where to start and where to stop.";
        if (step.Name.Contains("Purify Template")) return "The cutting step left behind enzyme fragments and buffer chemicals mixed with our DNA. We need to clean it up — like filtering out coffee grounds before drinking. The spin column traps the DNA while washing away everything else.";
        if (step.Name.Contains("QC") && step.Name.Contains("Template")) return "Before starting the expensive main reaction, we check that our DNA template is clean and concentrated enough. The UV spectrophotometer shines ultraviolet light through the sample — DNA absorbs UV at a specific wavelength (260nm), so the amount absorbed tells us how much DNA we have.";
        if (step.Name.Contains("IVT:")) return "This is THE key step — in vitro transcription (IVT). The T7 enzyme reads the DNA template and builds mRNA copies, letter by letter. We use a modified 'letter' (m1-pseudouridine instead of regular uridine) so the mRNA won't trigger your immune system's alarms. The CleanCap reagent adds a special cap to the front of the mRNA that tells your cells' ribosomes 'this is real — start translating me into protein.'";
        if (step.Name.Contains("DNase")) return "We now have mRNA — but the original DNA template is still in the mix. We need to destroy it because we only want to deliver mRNA (which is temporary) not DNA (which could integrate into chromosomes). DNase is an enzyme that chews up DNA but leaves RNA untouched.";
        if (step.Name.Contains("Purify mRNA")) return "Clean-up time again. The mixture contains our mRNA plus leftover enzymes, unused building blocks, and DNA fragments. The spin column captures only the mRNA. From this point on, keep everything cold (on ice) — mRNA degrades quickly at room temperature.";
        if (step.Name.Contains("QC Yield") || step.Name.Contains("QC:") && step.Name.Contains("Yield")) return "Quality control — checking that we made enough mRNA and it's pure. A260 measures RNA concentration. The 260/280 ratio tells us about purity: ~2.0 means pure RNA, lower means contamination with protein or chemicals.";
        if (step.Name.Contains("QC Gel")) return "We run the mRNA on a gel (like a molecular race track) to check its size. Electrical current pushes the mRNA through a gel matrix — smaller molecules run faster. We compare our mRNA band position to a known size ladder. One clean band at the right size = good. Smearing = degraded. Multiple bands = something went wrong.";
        if (step.Name.Contains("Combine")) return "Some therapies use multiple mRNAs (e.g., Oct4 + Sox2 + Klf4 for rejuvenation). We mix them in equal amounts so each cell receives balanced instructions.";
        if (step.Name.Contains("LNP")) return "Naked mRNA would be destroyed by enzymes in your blood within seconds. We wrap it in lipid nanoparticles (LNPs) — tiny fat bubbles about 80 nanometers across (1000x smaller than a human hair). The two syringe pumps mix mRNA (in water) with lipids (in ethanol) through a tiny junction at a precise 3:1 ratio. The rapid mixing causes the lipids to spontaneously form bubbles around the mRNA.";
        if (step.Name.Contains("Buffer Exchange")) return "The LNP mixture still contains ethanol from the lipid solution. We remove it by dialysis — placing the mixture in a bag with tiny pores, sitting in a large volume of clean buffer (PBS). The ethanol diffuses out through the pores while the LNPs are too big to escape. Like tea leaves in a tea bag, but in reverse.";
        if (step.Name.Contains("QC: LNP") || step.Name.Contains("QC: Final")) return "Final quality check: how much mRNA actually made it inside the LNPs? We add a detergent (Triton X-100) to pop open the bubbles, then measure the mRNA that was inside. We compare this to the total mRNA we started with — ideally over 80% should be encapsulated.";
        if (step.Name.Contains("Hydrogel")) return "For wound healing, we mix the LNPs into a gel that can be spread on the wound. The gel (hyaluronic acid) keeps the LNPs in contact with the wound bed and provides moisture for healing.";
        if (step.Name.Contains("Microneedle")) return "For hair regrowth, we load the LNPs into dissolving microneedle patches — tiny needles (0.6mm long) that painlessly penetrate the scalp to deliver mRNA directly to the hair follicle stem cells.";
        if (step.Name.Contains("Nebulizer")) return "For cold treatment, we load the LNPs into a nebulizer that turns the liquid into a fine mist you breathe in, delivering the mRNA directly to your airways where the virus lives.";
        if (step.Name.Contains("Storage")) return "mRNA is fragile — it needs to be stored at -80°C to prevent degradation. At this temperature, it's stable for 6+ months. Always use single-use portions — each freeze-thaw cycle damages some of the mRNA.";
        return step.Description;
    }

    static string GetPlainInstruction(IvtStep step)
    {
        if (step.Name.Contains("Template Prep")) return "Take the plasmid tube (tiny tube from Addgene, stored in your -20°C freezer). Thaw it by holding it in your hand for 1 minute. Add the restriction enzyme (comes with the kit — it's the one labeled with the enzyme name on the protocol). Mix gently by flicking the tube. Put it in the heat block. The app will set the temperature to 37°C automatically. Wait 1 hour.";
        if (step.Name.Contains("Purify Template")) return "Take a spin column from the cleanup kit (small white tube with a filter inside). Add your reaction to the column. Put it in the centrifuge — the app will start it automatically at 8000 RPM for 5 minutes. The DNA sticks to the filter. Wash with the buffer from the kit (follow the kit instructions). Spin again. Add clean water to release the DNA into a new collection tube.";
        if (step.Name.Contains("QC") && step.Name.Contains("Template")) return "Take 1-2 microliters (a tiny drop — use the smallest pipette) and put it in the spectrophotometer cuvette (the small glass square). The app will automatically take a UV measurement. Look at the numbers: you want at least 50 ng/µL concentration and a 260/280 ratio of 1.8 or higher.";
        if (step.Name.Contains("IVT:")) return "This is the big one. In a fresh tube on ice, add: the 10x buffer (2µL), your template DNA (1µL), the NTP mix with modified uridine (replace the regular UTP), CleanCap reagent, T7 enzyme (1µL), and water to 20µL total. Follow the kit's exact volumes. Mix gently — DO NOT vortex (shaking destroys the enzyme). Put in the heat block at 37°C. The app starts the timer automatically. Do not open or disturb the tube for 2 hours.";
        if (step.Name.Contains("DNase")) return "Open the tube carefully. Add 1µL of DNase I (in the kit). Close the tube and flick gently to mix. Put it back in the heat block at 37°C for 15 minutes. The timer starts automatically.";
        if (step.Name.Contains("Purify mRNA")) return "Same as the template cleanup — but use the RNA cleanup kit (different columns, RNA-specific). Add your reaction to the column, spin in the centrifuge (auto-started), wash, spin again, elute with 50µL of RNase-free water into a clean tube. Keep the tube ON ICE from now on. mRNA degrades quickly at room temperature.";
        if (step.Name.Contains("QC Yield") || step.Name.Contains("QC:") && step.Name.Contains("Yield")) return "Put a tiny drop in the spectrophotometer. The app measures automatically. Check: 260/280 ratio should be ~2.0 (pure RNA). Concentration should be 2000-3600 ng/µL. If it's too low, you can repeat the IVT step with more template.";
        if (step.Name.Contains("QC Gel")) return "Prepare the gel: mix 1g agarose powder in 100mL TAE buffer, microwave until dissolved, add GelRed stain, pour into the gel box and insert the comb. Wait 20 min for it to solidify. Remove comb. Load 1µL of RNA ladder in the first well, then 1µL of your mRNA mixed with loading dye in the next well. The app starts the gel at 100V for 30 minutes. After it finishes, look at the gel under blue light — you should see one clean band.";
        if (step.Name.Contains("Combine")) return "Using the concentrations from the spectrophotometer, calculate how much of each mRNA to mix so they're in equal amounts. For 3 mRNAs of different lengths, you need to account for molecular weight. The app notes explain the formula. Mix them in a tube on ice.";
        if (step.Name.Contains("LNP")) return "Prepare two syringes: Syringe A = your mRNA mixed in citrate buffer (pH 4.0 — check with pH meter). Syringe B = lipids dissolved in ethanol. Load them into Pump A and Pump B. Connect both pumps to the T-junction mixer with tubing. Place a collection vial at the output. Click Next — the app starts both pumps automatically at 9 mL/min (A) and 3 mL/min (B) for the precise 3:1 ratio needed.";
        if (step.Name.Contains("Buffer Exchange")) return "Take the collected LNP mixture and put it into a dialysis cassette (a flat pouch with a tiny-pore membrane). Place the cassette in a large beaker filled with 1 liter of PBS buffer (salt water at body-compatible pH). Wait 1 hour. Replace the PBS with fresh PBS. Wait another hour. The ethanol gradually leaks out through the membrane while the LNPs stay inside.";
        if (step.Name.Contains("QC: LNP") || step.Name.Contains("QC: Final")) return "Take two small samples: (1) measure the total mRNA by adding detergent (Triton X-100 — it pops open the LNPs to release the mRNA inside), then measure with spectrophotometer. (2) measure without detergent (this measures any mRNA that DIDN'T get encapsulated). Encapsulation efficiency = (total - free) / total × 100%. You want over 80%.";
        if (step.Name.Contains("Hydrogel")) return "In a clean container, mix equal volumes of your LNP solution and 2% hyaluronic acid gel. Stir gently with a spatula — DO NOT shake or vortex (the shaking forces would destroy the delicate LNP bubbles). The result should be a smooth, spreadable gel. Store at 2-8°C (fridge), use within 24 hours.";
        if (step.Name.Contains("Microneedle")) return "Concentrate the LNPs by spinning through a centrifuge filter (the 100kDa Amicon Ultra — it lets water through but keeps the LNPs). Pour the concentrated LNPs into the microneedle mold (PVP/PVA polymer). Let it dry in a sealed container with desiccant (moisture absorber) at room temperature for 24 hours. Store finished patches at -20°C.";
        if (step.Name.Contains("Nebulizer")) return "Transfer the LNP solution into the nebulizer reservoir (the small cup on the device). Use a vibrating mesh nebulizer ONLY — jet nebulizers use high-pressure air that destroys the LNP bubbles. Store ready-to-use solution at 2-8°C, use within 4 hours.";
        if (step.Name.Contains("Storage")) return "Divide your finished product into small single-use portions (aliquots). Label each tube with: date, therapy name, concentration, and volume. Place in a box in the -80°C freezer. When you need one, take out a single tube and let it thaw at room temperature for 15 minutes. NEVER refreeze a thawed tube — the freeze-thaw cycle damages the LNPs.";
        return step.Description;
    }

    private void ToggleAllergen(string name, bool add)
    {
        if (add && !_allergens.Contains(name)) _allergens.Add(name);
        else _allergens.Remove(name);
    }

    public async ValueTask DisposeAsync()
    {
        StopTimer();
        LabClient.OnStatusChanged -= () => InvokeAsync(StateHasChanged);
        await LabClient.DisconnectAsync();
        await EnvClient.DisconnectAsync();
        await QcClient.DisconnectAsync();
    }
}
