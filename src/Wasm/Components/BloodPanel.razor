@code {
    [Parameter] public Core.Models.BloodPanel Blood { get; set; } = new();
}

<fieldset>
    <legend>Blood Panel &mdash; PhenoAge 9 Biomarkers (Required)</legend>
    <p class="panel-note">These are standard lab values from a comprehensive metabolic panel (CMP) + CBC.</p>
    <div class="form-grid">
        <label>
            Albumin (g/dL)
            <input type="number" step="0.1" min="0.5" max="8" @bind="Blood.Albumin" />
            <small>Normal: 3.5-5.5</small>
        </label>
        <label>
            Alkaline Phosphatase (U/L)
            <input type="number" step="1" min="5" max="1000" @bind="Blood.AlkalinePhosphatase" />
            <small>Normal: 44-147</small>
        </label>
        <label>
            Creatinine (mg/dL)
            <input type="number" step="0.1" min="0.1" max="20" @bind="Blood.Creatinine" />
            <small>Normal: 0.7-1.3</small>
        </label>
        <label>
            C-Reactive Protein (mg/dL)
            <input type="number" step="0.1" min="0.001" max="50" @bind="Blood.CReactiveProtein" />
            <small>Normal: 0.0-1.0 (log-transformed in calculation)</small>
        </label>
        <label>
            Fasting Glucose (mg/dL)
            <input type="number" step="1" min="20" max="600" @bind="Blood.FastingGlucose" />
            <small>Normal: 70-100</small>
        </label>
        <label>
            White Blood Cell Count (10^3/uL)
            <input type="number" step="0.1" min="0.5" max="50" @bind="Blood.WhiteBloodCellCount" />
            <small>Normal: 4.5-11.0</small>
        </label>
        <label>
            Lymphocyte %
            <input type="number" step="1" min="1" max="80" @bind="Blood.LymphocytePercent" />
            <small>Normal: 20-40%</small>
        </label>
        <label>
            Mean Cell Volume (fL)
            <input type="number" step="1" min="50" max="130" @bind="Blood.MeanCellVolume" />
            <small>Normal: 80-100</small>
        </label>
        <label>
            Red Cell Distribution Width (%)
            <input type="number" step="0.1" min="8" max="30" @bind="Blood.RedCellDistWidth" />
            <small>Normal: 11.5-14.5</small>
        </label>
    </div>
</fieldset>
