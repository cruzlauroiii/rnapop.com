    private string GetProtocolSlug(int idx)
    {
        if (_protocol is null || idx >= _protocol.Steps.Length) return "complete";
        // Use predefined slug if available, otherwise generate from step name
        if (idx < ProtocolSlugs.Length) return ProtocolSlugs[idx];
        return _protocol.Steps[idx].Name.ToLower()
            .Replace(" ", "-").Replace(":", "").Replace("(", "").Replace(")", "")
            .Replace("--", "-").Trim('-');
    }

    private void UpdateUrl()
    {
        string url = _phase == Phase.ProtocolStep
            ? $"guide/make/{GetProtocolSlug(_protocolStepIdx)}"
            : $"guide/{StepSlugs[(int)_phase]}";
        Nav.NavigateTo(url, replace: true);
    }

    private bool CanGoNext => _phase switch
    {
        Phase.Welcome => true,
        Phase.ChooseTherapy => _selectedTherapy is not null,
        Phase.LearnTherapy => true,
        Phase.EnterInfo => true,
        Phase.ShowResult => true,
        Phase.ConnectLab => true,  // Always clickable — first click connects, second click proceeds
        Phase.ProtocolStep => true,  // Always clickable — timer is informational, not blocking
        _ => true,
    };

    private string NextButtonText => _phase switch
    {
        Phase.Welcome => "Let's get started",
        Phase.ChooseTherapy => _selectedTherapy is not null ? $"Learn about {_selectedTherapy.Name}" : "Pick a therapy first",
        Phase.LearnTherapy => "Next — enter my info",
        Phase.EnterInfo => "Check if this is right for me",
        Phase.ShowResult => "Next — connect my lab",
        Phase.ConnectLab when !LabClient.Connected && _connectError is null => "Connect to lab",
        Phase.ConnectLab when !LabClient.Connected => "Continue in simulation mode",
        Phase.ConnectLab => "Next — start making the mRNA",
        Phase.ProtocolStep when _protocol is not null && _protocolStepIdx >= _protocol.Steps.Length => "Finish",
        Phase.ProtocolStep when _timerRunning && _timerRemaining > 0 => $"Next ({_timerRemaining / 60}:{(_timerRemaining % 60):D2} remaining — or skip)",
        Phase.ProtocolStep => "Next step",
        _ => "Next",
    };

    protected override void OnInitialized()
    {
        LabClient.OnStatusChanged += () => InvokeAsync(StateHasChanged);
        EnvClient.OnStatusChanged += () => InvokeAsync(StateHasChanged);
    }

    private async Task Next()
    {
        switch (_phase)
        {
            case Phase.Welcome:
                _phase = Phase.ChooseTherapy; _step++; break;
            case Phase.ChooseTherapy:
                _phase = Phase.LearnTherapy; _step++; break;
            case Phase.LearnTherapy:
                _phase = Phase.EnterInfo; _step++; break;
            case Phase.EnterInfo:
                _input.TherapyId = _selectedTherapy!.Id;
                _input.Allergens = _allergens.ToArray();
                _result = TherapyScorer.Score(_input);
                _phase = Phase.ShowResult; _step++;
                break;
            case Phase.ShowResult:
                _phase = Phase.ConnectLab; _step++; break;
            case Phase.ConnectLab:
                if (!LabClient.Connected && _connectError is null)
                {
                    // First click: try to connect
                    try
                    {
                        await Task.WhenAll(LabClient.ConnectAsync(_wssUrl), EnvClient.ConnectAsync(_wssUrl), QcClient.ConnectAsync(_wssUrl));
                        if (!LabClient.Connected) _connectError = LabClient.Error ?? "Connection failed";
                    }
                    catch (Exception ex) { _connectError = ex.Message; }

                    // If connected, proceed immediately
                    if (LabClient.Connected)
                    {
                        _simulation = false;
                        _protocol = TherapyProtocols.GetProtocol(_selectedTherapy!.Id);
                        _protocolStepIdx = 0;
                        _phase = Phase.ProtocolStep; _step++;
                        StartProtocolStep();
                    }
                }
                else
                {
                    // Second click (or already connected): proceed
                    if (!LabClient.Connected) _simulation = true; // No connection = simulation mode
                    _protocol = TherapyProtocols.GetProtocol(_selectedTherapy!.Id);
                    _protocolStepIdx = 0;
                    _phase = Phase.ProtocolStep; _step++;
                    StartProtocolStep();
                }
                break;
            case Phase.ProtocolStep:
                if (_protocol is not null && _protocolStepIdx < _protocol.Steps.Length)
                {
                    _protocol.Steps[_protocolStepIdx].Completed = true;
                    _protocolStepIdx++;
                    _step++;
                    StopTimer();
                    if (_protocolStepIdx < _protocol.Steps.Length) StartProtocolStep();
                }
                else { _step = 0; _phase = Phase.Welcome; } // Restart
                break;
        }
        UpdateUrl();
    }

    private void Back()
    {
        StopTimer();
        if (_phase == Phase.ProtocolStep && _protocolStepIdx > 0) { _protocolStepIdx--; _step--; StartProtocolStep(); }
        else if (_phase > Phase.Welcome) { _phase--; _step = Math.Max(0, _step - 1); }
        UpdateUrl();
    }

    private void StartProtocolStep()
    {
        if (_protocol is null || _protocolStepIdx >= _protocol.Steps.Length) return;
        var ps = _protocol.Steps[_protocolStepIdx];

        // Auto-send equipment commands
        if (LabClient.Connected && ps.Equipment != EquipmentType.None)
        {
            _ = ps.Equipment switch
            {
                EquipmentType.HeatBlock => Task.WhenAll(LabClient.SendCommandAsync(LabCommand.HeatBlockSetTemp, value: ps.Temperature), LabClient.SendCommandAsync(LabCommand.HeatBlockStart)),
                EquipmentType.Centrifuge => LabClient.SendCommandAsync(LabCommand.CentrifugeStart, value: ps.TargetRpm, value2: ps.DurationMinutes * 60),
                EquipmentType.Spectrophotometer => LabClient.SendCommandAsync(LabCommand.SpectrometerMeasure),
                EquipmentType.GelElectrophoresis => LabClient.SendCommandAsync(LabCommand.GelStart, value: ps.Voltage, value2: ps.DurationMinutes),
                EquipmentType.SyringePump => Task.WhenAll(LabClient.SendCommandAsync(LabCommand.PumpSetFlow, 0, 9, 3), LabClient.SendCommandAsync(LabCommand.PumpSetFlow, 1, 3, 1)),
                _ => Task.CompletedTask,
            };
        }

        // Auto-start timer if step has duration
        if (ps.DurationMinutes > 0)
        {
            // In simulation mode: 5 seconds per step instead of real minutes
            _timerTotal = _simulation ? 5 : ps.DurationMinutes * 60;
            _timerRemaining = _timerTotal;
            _timerRunning = true;
            _timer = new System.Threading.Timer(_ =>
            {
                _timerRemaining--;
                if (_timerRemaining <= 0) { _timerRunning = false; _timer?.Dispose(); }
                InvokeAsync(StateHasChanged);
            }, null, 1000, 1000);
        }
    }

    private void StopTimer()
    {
        _timerRunning = false;
        _timerRemaining = 0;
        _timer?.Dispose();
        _timer = null;
    }

